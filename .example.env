# ------------------------------
# Server
# ------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
APP_NAME=CODI-IT
LOG_LEVEL=debug

# ------------------------------
# Database
# Docker Compose에서 사용하는 기본 설정값입니다.
# ------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codi-it

# Prisma 연결 주소
# 로컬 Docker 접속용 주소입니다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codi-it?schema=public"

# ------------------------------
# Security & JWT
# ------------------------------
BCRYPT_SALT_ROUNDS=10
ACCESS_TOKEN_SECRET_KEY=
REFRESH_TOKEN_SECRET_KEY=
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------
# Rate Remit
# ------------------------------
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# ------------------------------
# Compression
# ------------------------------
COMPRESSION_THRESHOLD=
COMPRESSION_LEVEL=

# ------------------------------
# 동시 로그인 가능 기기 수
# ------------------------------
MAX_DEVICE=
