# ------------------------------
# Server
# ------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
APP_NAME=CODI-IT
LOG_LEVEL=debug

# ------------------------------
# Database
# Docker Compose에서 사용하는 기본 설정값입니다.
# ------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codi-it

# Prisma 연결 주소
# 로컬 Docker 접속용 주소입니다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codi-it?schema=public"

# ------------------------------
# Security & JWT
# ------------------------------
BCRYPT_SALT_ROUNDS=10
ACCESS_TOKEN_SECRET_KEY=
REFRESH_TOKEN_SECRET_KEY=
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------
# Rate Remit
# ------------------------------
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# ------------------------------
# Compression
# ------------------------------
COMPRESSION_THRESHOLD=
COMPRESSION_LEVEL=

# ------------------------------
# 동시 로그인 가능 기기 수
# ------------------------------
MAX_DEVICE=

# ------------------------------
# AWS S3
# ------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_BUCKET_NAME=codi-it-team5-storage

# ------------------------------
# 기본 리소스
# ------------------------------
DEFAULT_IMAGE_ID=
DEFAULT_IMAGE_URL=
DEFAULT_IMAGE_KEY=

# ------------------------------
# Cron Job (데이터 보관 정책)
# - 프로덕션: '0 3 * * *' (매일 오전 3시)
# - 개발/테스트: '*/5 * * * *' (5분마다)
# ------------------------------
CRON_SCHEDULE=*/5 * * * *

# 배치 삭제 설정
CRON_BATCH_SIZE=1000
CRON_BATCH_DELAY=100

# 데이터 보관 기간 (일)
RETENTION_DAYS_TAX_DATA=1825      # 5년 (전자상거래법, 국세기본법)
RETENTION_DAYS_USER_DATA=30       # 30일
RETENTION_DAYS_AUTH_DATA=90       # 3개월 (통신비밀보호법)