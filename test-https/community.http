
@accessToken = {{auth.response.body.accessToken}}
@productId =
@inquiryId =
@replyId =
@reviewId =
@orderItemId =

### 로그인
# @name auth
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
User-Agent: rest-client-test

{
  "email": "buyer1@test.com",
  "password": "test1234"
}


### 문의 등록
POST {{baseUrl}}/api/products/testProductId/inquiries
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "상품 문의드립니다",
  "content": "배송은 얼마나 걸리나요?",
  "isSecret": false
}

### 상품별 문의 조회
GET {{baseUrl}}/api/products/testProductId/inquiries

### 내 문의 조회
GET {{baseUrl}}/api/inquiries
Authorization: Bearer {{accessToken}}

### 문의 상세 조회
GET {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}

### 문의 수정
PATCH {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "상품 문의드립니다 (수정)",
  "content": "배송은 얼마나 걸리나요? (추가 질문)",
  "isSecret": false
}

### 문의 삭제
DELETE {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}

### 답변 등록
POST {{baseUrl}}/inquiries/{{inquiryId}}/replies
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "보통 2-3일 정도 소요됩니다."
}

### 답변 상세 조회
GET {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}

### 답변 수정
PATCH {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "보통 2-3일 정도 소요되며, 빠른 배송도 가능합니다."
}

### 답변 삭제
DELETE {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}
