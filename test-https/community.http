
@accessToken = {{auth.response.body.accessToken}}
@productId =
@inquiryId =
@replyId =
@reviewId =
@orderItemId =

### 문의 등록
POST {{baseUrl}}/products/{{productId}}/inquiries
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "상품 문의드립니다",
  "content": "배송은 얼마나 걸리나요?",
  "isSecret": false
}

### 상품별 문의 조회
GET {{baseUrl}}/products/{{productId}}/inquiries

### 내 문의 조회
GET {{baseUrl}}/inquiries
Authorization: Bearer {{accessToken}}

### 문의 상세 조회
GET {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}

### 문의 수정
PATCH {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "상품 문의드립니다 (수정)",
  "content": "배송은 얼마나 걸리나요? (추가 질문)",
  "isSecret": false
}

### 문의 삭제
DELETE {{baseUrl}}/inquiries/{{inquiryId}}
Authorization: Bearer {{accessToken}}

### 답변 등록
POST {{baseUrl}}/inquiries/{{inquiryId}}/replies
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "보통 2-3일 정도 소요됩니다."
}

### 답변 상세 조회
GET {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}

### 답변 수정
PATCH {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "보통 2-3일 정도 소요되며, 빠른 배송도 가능합니다."
}

### 답변 삭제
DELETE {{baseUrl}}/inquiries/{{replyId}}/replies
Authorization: Bearer {{accessToken}}

### 리뷰 작성
POST {{baseUrl}}/products/{{productId}}/reviews
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "rating": 5,
  "content": "상품 정말 좋아요! 강력 추천합니다.",
  "orderItemId": "{{orderItemId}}"
}

### 상품별 리뷰 조회
GET {{baseUrl}}/products/{{productId}}/reviews

### 내 리뷰 조회
GET {{baseUrl}}/reviews
Authorization: Bearer {{accessToken}}

### 리뷰 상세 조회
GET {{baseUrl}}/reviews/{{reviewId}}

### 리뷰 수정
PATCH {{baseUrl}}/reviews/{{reviewId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "rating": 4,
  "content": "상품은 좋은데 배송이 조금 느렸어요."
}

### 리뷰 삭제
DELETE {{baseUrl}}/reviews/{{reviewId}}
Authorization: Bearer {{accessToken}}
