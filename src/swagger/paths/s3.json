{
  "/api/s3/upload": {
    "post": {
      "tags": ["S3"],
      "summary": "이미지 업로드",
      "description": "AWS S3에 이미지 업로드. 지원 형식: JPEG, PNG, GIF, WebP. 최대 5MB",
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "image": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "업로드 성공",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "imageId": { "type": "string" },
                  "imageUrl": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
