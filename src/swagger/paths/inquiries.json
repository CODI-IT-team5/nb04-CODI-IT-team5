{
  "/api/products/{productId}/inquiries": {
    "get": {
      "tags": ["Inquiries"],
      "summary": "상품 문의 목록 조회",
      "parameters": [{ "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inquiries": { "type": "array", "items": { "$ref": "#/components/schemas/Inquiry" } },
                  "totalCount": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    },
    "post": {
      "tags": ["Inquiries"],
      "summary": "상품 문의 등록",
      "description": "구매자 전용",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["content"],
              "properties": {
                "content": { "type": "string" },
                "isSecret": { "type": "boolean", "default": false }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "문의 등록 성공",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Inquiry" }
            }
          }
        }
      }
    }
  },
  "/api/inquiries": {
    "get": {
      "tags": ["Inquiries"],
      "summary": "내 문의 목록 조회",
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        { "name": "page", "in": "query", "schema": { "type": "integer" } },
        { "name": "pageSize", "in": "query", "schema": { "type": "integer" } },
        { "name": "status", "in": "query", "schema": { "$ref": "#/components/schemas/InquiryStatus" } }
      ],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inquiries": { "type": "array", "items": { "$ref": "#/components/schemas/Inquiry" } },
                  "totalCount": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    }
  },
  "/api/inquiries/{inquiryId}": {
    "get": {
      "tags": ["Inquiries"],
      "summary": "문의 상세 조회",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Inquiry" }
            }
          }
        }
      }
    },
    "patch": {
      "tags": ["Inquiries"],
      "summary": "문의 수정",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "content": { "type": "string" },
                "isSecret": { "type": "boolean" }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "수정 성공"
        }
      }
    },
    "delete": {
      "tags": ["Inquiries"],
      "summary": "문의 삭제",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "responses": {
        "200": {
          "description": "삭제 성공"
        }
      }
    }
  },
  "/api/inquiries/{inquiryId}/replies": {
    "get": {
      "tags": ["Inquiries"],
      "summary": "문의 답변 조회",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "responses": {
        "200": {
          "description": "조회 성공"
        }
      }
    },
    "post": {
      "tags": ["Inquiries"],
      "summary": "문의 답변 등록",
      "description": "판매자 전용",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["content"],
              "properties": {
                "content": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "답변 등록 성공"
        }
      }
    },
    "delete": {
      "tags": ["Inquiries"],
      "summary": "문의 답변 삭제",
      "description": "판매자 전용",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "inquiryId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "responses": {
        "200": {
          "description": "삭제 성공"
        }
      }
    }
  },
  "/api/inquiries/{replyId}/replies": {
    "patch": {
      "tags": ["Inquiries"],
      "summary": "문의 답변 수정",
      "description": "판매자 전용",
      "security": [{ "bearerAuth": [] }],
      "parameters": [{ "name": "replyId", "in": "path", "required": true, "schema": { "type": "string" } }],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "content": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "수정 성공"
        }
      }
    }
  }
}
