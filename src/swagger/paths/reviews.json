{
  "/api/product/{productId}/reviews": {
    "get": {
      "tags": ["Reviews"],
      "summary": "상품 리뷰 목록 조회",
      "parameters": [
        { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reviews": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } },
                  "totalCount": { "type": "integer" },
                  "averageRating": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "post": {
      "tags": ["Reviews"],
      "summary": "리뷰 작성",
      "description": "구매자 전용, 구매한 상품만 작성 가능",
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["orderItemId", "rating", "content"],
              "properties": {
                "orderItemId": { "type": "string" },
                "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                "content": { "type": "string" },
                "imageId": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "리뷰 작성 성공",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Review" }
            }
          }
        }
      }
    }
  },
  "/api/review": {
    "get": {
      "tags": ["Reviews"],
      "summary": "내 리뷰 목록 조회",
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reviews": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } }
                }
              }
            }
          }
        }
      }
    }
  },
  "/api/review/{reviewId}": {
    "get": {
      "tags": ["Reviews"],
      "summary": "리뷰 상세 조회",
      "parameters": [
        { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "조회 성공",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Review" }
            }
          }
        }
      }
    },
    "patch": {
      "tags": ["Reviews"],
      "summary": "리뷰 수정",
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "rating": { "type": "integer" },
                "content": { "type": "string" },
                "imageId": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "수정 성공"
        }
      }
    },
    "delete": {
      "tags": ["Reviews"],
      "summary": "리뷰 삭제",
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "삭제 성공"
        }
      }
    }
  }
}
